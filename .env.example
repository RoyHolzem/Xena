# ── Client-side (safe, public) ──
NEXT_PUBLIC_APP_NAME=Xena
NEXT_PUBLIC_ASSISTANT_NAME=Xena
NEXT_PUBLIC_GATEWAY_URL=https://your-gateway-url
NEXT_PUBLIC_GATEWAY_CHAT_PATH=/v1/chat/completions

# Cognito (auto-set by CloudFormation / Amplify env vars)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=eu-central-1_xxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_COGNITO_REGION=eu-central-1

# ── Server-side (NEVER expose to browser — no NEXT_PUBLIC_ prefix) ──
GATEWAY_AUTH_TOKEN=replace-me
CT_AWS_ACCESS_KEY_ID=replace-me
CT_AWS_SECRET_ACCESS_KEY=replace-me
CT_AWS_REGION=eu-central-1
